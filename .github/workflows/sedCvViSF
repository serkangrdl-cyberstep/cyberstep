name: CyberStep Lead Discovery (Certstream)

on:
  workflow_dispatch:

jobs:
  discover:
    runs-on: ubuntu-latest
    timeout-minutes: 14

    steps:
      - name: Install dependencies
        run: pip install websockets

      - name: Download and start certstream-server-go
        run: |
          curl -fsSL             "https://github.com/d-Rickyy-b/certstream-server-go/releases/download/v1.9.0/certstream-server-go_1.9.0_linux_amd64"             -o certstream-server-go
          chmod +x certstream-server-go

          # Minimal config — sadece port ayarı, default CT logları kullanılır
          echo "d2Vic2VydmVyOgogIGxpc3Rlbl9hZGRyOiAiMC4wLjAuMCIKICBsaXN0ZW5fcG9ydDogODA4MAogIGRvbWFpbnNfb25seV91cmw6ICIvZG9tYWlucy1vbmx5Igo=" | base64 -d > config.yml
          echo "=== config.yml ===" && cat config.yml

          ./certstream-server-go > certstream.log 2>&1 &
          echo "CERTSTREAM_PID=$!" >> $GITHUB_ENV

          # Port 8080 açılana kadar bekle (max 90s)
          for i in $(seq 1 90); do
            if nc -z localhost 8080 2>/dev/null; then
              echo "Port 8080 OPEN after ${i}s"
              break
            fi
            sleep 1
          done
          ss -tlnp | grep 8080 || echo "Port 8080 NOT open"

          echo "=== certstream.log (ilk 20 satır) ===" && head -20 certstream.log || true

      - name: Collect TR domains and send to Replit
        env:
          REPLIT_INGEST_URL: ${{ secrets.REPLIT_INGEST_URL }}
          BRIDGE_SECRET: ${{ secrets.BRIDGE_SECRET }}
        run: |
          python3 << 'PYEOF'
          import asyncio, json, os, sys, time
          import websockets
          import urllib.request

          REPLIT_URL = os.environ.get("REPLIT_INGEST_URL", "")
          SECRET     = os.environ.get("BRIDGE_SECRET", "")

          if not REPLIT_URL or not SECRET:
              print("ERROR: REPLIT_INGEST_URL veya BRIDGE_SECRET eksik", flush=True)
              sys.exit(1)

          TR_TLDS = (
              ".com.tr", ".net.tr", ".org.tr", ".web.tr",
              ".biz.tr", ".info.tr", ".gen.tr", ".tv.tr", ".name.tr",
          )
          SKIP_TLDS  = (".gov.tr", ".edu.tr", ".k12.tr", ".mil.tr", ".bel.tr", ".pol.tr")
          SKIP_HOSTS = {
              "cloudflare.com", "amazonaws.com", "azure.com",
              "google.com", "microsoft.com", "letsencrypt.org",
          }

          collected: set[str] = set()

          def is_tr_lead(d: str) -> bool:
              d = d.lower().lstrip("*.")
              if any(d.endswith(s) for s in SKIP_TLDS): return False
              if any(h in d for h in SKIP_HOSTS): return False
              return any(d.endswith(t) for t in TR_TLDS)

          def root_domain(d: str) -> str:
              parts = d.lower().lstrip("*.").split(".")
              if len(parts) >= 3 and parts[-1] == "tr":
                  return ".".join(parts[-3:])
              return ".".join(parts[-2:])

          WS_URL = "ws://localhost:8080/domains-only"
          COLLECT_SECONDS = 480  # 8 dakika

          async def collect():
              start    = time.time()
              deadline = start + COLLECT_SECONDS
              total_messages = 0
              tr_raw_hits    = 0
              print(f"Connecting to {WS_URL} ...", flush=True)

              try:
                  async with websockets.connect(
                      WS_URL,
                      max_size=None,
                      compression=None,
                      ping_interval=None,
                      open_timeout=15,
                  ) as ws:
                      print("Connected! 8 dakika TR domain toplanıyor...", flush=True)

                      while time.time() < deadline:
                          try:
                              remaining = deadline - time.time()
                              if remaining <= 0:
                                  break
                              msg = await asyncio.wait_for(
                                  ws.recv(),
                                  timeout=min(remaining, 30.0),
                              )
                          except asyncio.TimeoutError:
                              continue
                          except Exception as e:
                              print(f"  recv error: {e}", flush=True)
                              break

                          total_messages += 1

                          if isinstance(msg, bytes):
                              msg = msg.decode("utf-8", errors="ignore")
                          if ".tr" not in msg:
                              continue
                          tr_raw_hits += 1

                          try:
                              data = json.loads(msg)
                          except Exception:
                              continue

                          domains_in_msg: list[str] = []
                          if isinstance(data, list):
                              domains_in_msg = [d for d in data if isinstance(d, str)]
                          elif isinstance(data, dict):
                              data_field = data.get("data")
                              if isinstance(data_field, list):
                                  domains_in_msg = [d for d in data_field if isinstance(d, str)]
                              elif isinstance(data_field, dict):
                                  leaf = data_field.get("leaf_cert", {})
                                  domains_in_msg = [d for d in leaf.get("all_domains", []) if isinstance(d, str)]

                          for d in domains_in_msg:
                              if is_tr_lead(d):
                                  collected.add(root_domain(d))

                          if total_messages % 50000 == 0:
                              elapsed = int(time.time() - start)
                              print(
                                  f"  [{elapsed}s] msgs={total_messages} tr_hits={tr_raw_hits} TR={len(collected)}",
                                  flush=True,
                              )

              except Exception as e:
                  print(f"Connection error: {e}", flush=True)

              elapsed = int(time.time() - start)
              print(
                  f"Bitti — {elapsed}s | msgs={total_messages} tr_hits={tr_raw_hits} TR domains={len(collected)}",
                  flush=True,
              )

          asyncio.run(collect())

          if not collected:
              print("TR domain bulunamadı — gönderilecek bir şey yok", flush=True)
              sys.exit(0)

          domains = sorted(collected)
          print(f"Örnek: {domains[:5]}", flush=True)
          CHUNK = 500
          total_accepted = 0

          for i in range(0, len(domains), CHUNK):
              chunk = domains[i:i + CHUNK]
              payload = json.dumps({
                  "domains": chunk,
                  "secret": SECRET,
                  "source": "certstream-bridge",
              }).encode()
              try:
                  req = urllib.request.Request(
                      REPLIT_URL, data=payload,
                      headers={"Content-Type": "application/json"}, method="POST",
                  )
                  with urllib.request.urlopen(req, timeout=30) as resp:
                      body = json.loads(resp.read())
                      total_accepted += body.get("accepted", 0)
                      print(
                          f"  Batch {i//CHUNK+1}: accepted={body.get('accepted')} skipped={body.get('skipped')}",
                          flush=True,
                      )
              except Exception as e:
                  print(f"  Batch {i//CHUNK+1}: HATA {e}", flush=True)

          print(f"=== TAMAMLANDI: total_accepted={total_accepted} ===", flush=True)
          PYEOF

      - name: Stop certstream-server-go
        if: always()
        run: |
          kill $CERTSTREAM_PID 2>/dev/null || true
          echo "=== certstream.log (son 30 satır) ==="
          tail -30 certstream.log 2>/dev/null || echo "(no log)"
